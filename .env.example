# Viraly Environment Variables
# Copy to .env and fill in real values for production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
# For production: NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# API
JWT_SECRET=change-this-in-production
DATABASE_URL=postgresql://viraly:viraly@localhost:5433/viraly
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000

# AI (optional — mock mode if empty)
AI_PROVIDER_KEY=
AI_PROVIDER_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# Payment (optional — graceful fallback if empty)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Push Notifications (optional — disabled if empty)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:hello@viraly.app

# Google OAuth (optional — dev mock if empty)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
